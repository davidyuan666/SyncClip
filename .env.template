# === SyncCLIPAgent Environment Configuration ===
# Copy this file to .env and fill in your keys.
# .env is git-ignored and should NOT be committed.
#
# === Required: LLM API Key (choose one) ===
# OpenAI (paper uses GPT-4 Mini)
OPENAI_API_KEY=sk-your-openai-api-key-here
# DeepSeek (alternative, OpenAI-compatible)
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# === LLM Model Selection ===
MODEL=gpt-4-mini
STRUCT_MODEL=gpt-4-mini

# === Pexels / Pixabay (for downloading stock videos) ===
# PEXELS_API_KEY=your-pexels-key
# PIXABAY_API_KEY=your-pixabay-key

# === GPU Server Configuration (auto-detected by run_on_gpu_server.sh) ===
# SYNCCLIP_GPU=NVIDIA A100
# SYNCCLIP_GPU_MEMORY_GB=80
# SYNCCLIP_CPU=Intel Xeon
# SYNCCLIP_CPU_CORES=64
# SYNCCLIP_RAM_GB=512
# SYNCCLIP_CUDA_VERSION=12.1
# SYNCCLIP_PYTORCH_VERSION=2.2.2

# === Data Paths (default: experiments/data, experiments/output) ===
# SYNCCLIP_DATA_DIR=/data/videos
# SYNCCLIP_OUTPUT_DIR=/data/results
# SYNCCLIP_ANNOTATION_DIR=/data/annotations

# === Optional Services ===
# COS_ENABLED=0
# TTS_ENABLED=0
# XI_API_KEY=your-elevenlabs-key
# API_BASE_URL=

# === PyPI Mirrors (for China servers) ===
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
