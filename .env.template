# === SyncClipAgent Environment Configuration ===
# Copy this file to .env and fill in your keys.
# .env is git-ignored and should NOT be committed.

# DeepSeek API (recommended, OpenAI-compatible)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
MODEL=deepseek-chat
STRUCT_MODEL=deepseek-chat

# OpenAI API (fallback if DEEPSEEK_API_KEY is not set)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Pexels / Pixabay free stock video API (optional, for higher rate limits)
# PEXELS_API_KEY=your-pexels-key
# PIXABAY_API_KEY=your-pixabay-key

# Tencent COS cloud storage (optional, set COS_ENABLED=1 to use)
# COS_ENABLED=0

# ElevenLabs TTS (optional, set TTS_ENABLED=1 to use)
# TTS_ENABLED=0
# XI_API_KEY=your-elevenlabs-key

# API base URL override (optional, defaults to OpenAI/DeepSeek)
# API_BASE_URL=
